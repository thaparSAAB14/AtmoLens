{
  "version": 2,
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/.next",
  "framework": "nextjs",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "api/index.py"
    }
  ],
  "functions": {
    "api/**/*.py": {
      "runtime": "vercel-python@1.0.3"
    }
  },
  "crons": [
    {
      "path": "/api/cron/fetch-maps",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/cleanup",
      "schedule": "0 0 * * *"
    }
  ],
  "regions": ["iad1"]
}
