# AtmoLens Backend Environment Variables
# Copy this to .env and fill in your values

# Server Configuration
HOST=0.0.0.0
PORT=8001

# Frontend Origins (comma-separated for multiple)
# Local development:
FRONTEND_ORIGIN=http://localhost:3000

# Production (add your Vercel URL):
# FRONTEND_ORIGIN=https://your-app.vercel.app,http://localhost:3000

# Or multiple production domains:
# FRONTEND_ORIGIN=https://your-app.vercel.app,https://atmolens.com,http://localhost:3000

# Scheduler Settings
FETCH_INTERVAL_MINUTES=30
CLEANUP_HOUR=0
ARCHIVE_DAYS=7

# Image Processing
FOREGROUND_THRESHOLD=100
WATER_COLOR_BGR=226,144,74
LAND_COLOR_BGR=203,236,220

# Optional: Custom map output directory
# MAP_OUTPUT_DIR=/path/to/maps
